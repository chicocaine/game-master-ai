{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ActionOrClarify",
  "type": "object",
  "oneOf": [
    {
      "required": ["type", "question", "ambiguous_field"],
      "properties": {
        "type": {"const": "clarify"},
        "question": {"type": "string", "minLength": 1},
        "ambiguous_field": {"type": "string", "minLength": 1},
        "options": {
          "type": "array",
          "items": {
            "oneOf": [
              {"type": "string"},
              {
                "type": "object",
                "required": ["value"],
                "properties": {
                  "label": {"type": "string"},
                  "value": {"type": "string", "minLength": 1}
                },
                "additionalProperties": true
              }
            ]
          }
        },
        "action_template": {"type": "object"}
      },
      "additionalProperties": true
    },
    {
      "required": ["type", "parameters"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "abandon",
            "query",
            "converse",
            "move",
            "explore",
            "rest",
            "attack",
            "cast_spell",
            "end_turn",
            "start",
            "create_player",
            "remove_player",
            "choose_dungeon",
            "finish"
          ]
        },
        "actor_instance_id": {"type": "string"},
        "parameters": {"type": "object"},
        "raw_input": {"type": "string"},
        "reasoning": {"type": "string"},
        "metadata": {"type": "object"}
      },
      "additionalProperties": true
    }
  ]
}
