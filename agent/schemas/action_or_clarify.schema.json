{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ActionOrClarify",
  "type": "object",
  "$defs": {
    "actionParamsByType": {
      "allOf": [
        {
          "if": {"properties": {"type": {"const": "query"}}},
          "then": {"properties": {"parameters": {"required": ["question"]}}}
        },
        {
          "if": {"properties": {"type": {"const": "converse"}}},
          "then": {"properties": {"parameters": {"required": ["message"]}}}
        },
        {
          "if": {"properties": {"type": {"const": "move"}}},
          "then": {"properties": {"parameters": {"required": ["destination_room_id"]}}}
        },
        {
          "if": {"properties": {"type": {"const": "rest"}}},
          "then": {"properties": {"parameters": {"required": ["rest_type"]}}}
        },
        {
          "if": {"properties": {"type": {"const": "attack"}}},
          "then": {
            "required": ["actor_instance_id"],
            "properties": {"parameters": {"required": ["attack_id", "target_instance_ids"]}}
          }
        },
        {
          "if": {"properties": {"type": {"const": "cast_spell"}}},
          "then": {
            "required": ["actor_instance_id"],
            "properties": {"parameters": {"required": ["spell_id", "target_instance_ids"]}}
          }
        },
        {
          "if": {"properties": {"type": {"const": "create_player"}}},
          "then": {
            "properties": {
              "parameters": {
                "required": ["name", "description", "race", "archetype", "weapons"]
              }
            }
          }
        },
        {
          "if": {"properties": {"type": {"const": "remove_player"}}},
          "then": {"properties": {"parameters": {"required": ["player_instance_id"]}}}
        },
        {
          "if": {"properties": {"type": {"const": "choose_dungeon"}}},
          "then": {"properties": {"parameters": {"required": ["dungeon_id"]}}}
        }
      ]
    }
  },
  "oneOf": [
    {
      "required": ["type", "question", "ambiguous_field"],
      "properties": {
        "type": {"const": "clarify"},
        "question": {"type": "string", "minLength": 1},
        "ambiguous_field": {"type": "string", "minLength": 1},
        "options": {
          "type": "array",
          "items": {
            "oneOf": [
              {"type": "string"},
              {
                "type": "object",
                "required": ["value"],
                "properties": {
                  "label": {"type": "string"},
                  "value": {"type": "string", "minLength": 1}
                },
                "additionalProperties": true
              }
            ]
          }
        },
        "action_template": {"type": "object"}
      },
      "additionalProperties": true
    },
    {
      "required": ["type", "parameters"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "abandon",
            "query",
            "converse",
            "move",
            "explore",
            "rest",
            "attack",
            "cast_spell",
            "end_turn",
            "start",
            "create_player",
            "remove_player",
            "choose_dungeon",
            "finish"
          ]
        },
        "actor_instance_id": {"type": "string"},
        "parameters": {"type": "object"},
        "raw_input": {"type": "string"},
        "reasoning": {"type": "string"},
        "metadata": {"type": "object"}
      },
      "allOf": [{"$ref": "#/$defs/actionParamsByType"}],
      "additionalProperties": true
    }
  ]
}
