{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemata/attack.schema.json",
  "title": "Attack",
  "description": "Schema for serialized Attack model objects.",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "type",
    "parameters"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "melee",
        "ranged",
        "unarmed",
        "aoe_melee",
        "aoe_ranged",
        "aoe_unarmed"
      ]
    },
    "parameters": {
      "type": "object",
      "required": [
        "damage_types",
        "magnitude",
        "applied_status_effects",
        "hit_modifiers",
        "DC"
      ],
      "properties": {
        "damage_types": {
          "type": "array",
          "items": { "$ref": "#/$defs/damageType" }
        },
        "magnitude": { "type": "string", "minLength": 1 },
        "applied_status_effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/statusEffectReference" }
        },
        "hit_modifiers": { "type": "integer" },
        "DC": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "damageType": {
      "type": "string",
      "enum": [
        "acid",
        "bludgeoning",
        "cold",
        "fire",
        "force",
        "lightning",
        "necrotic",
        "piercing",
        "poison",
        "psychic",
        "radiant",
        "slashing",
        "thunder"
      ]
    },
    "statusEffectReference": {
      "type": "array",
      "prefixItems": [
        { "type": "string", "minLength": 1 },
        { "type": "integer" }
      ],
      "minItems": 2,
      "maxItems": 2,
      "items": false
    },
    "attackCollection": {
      "type": "array",
      "items": { "$ref": "#" }
    }
  }
}
