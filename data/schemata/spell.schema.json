{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemata/spell.schema.json",
  "title": "Spell",
  "description": "Schema for serialized Spell model objects.",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "type",
    "spell_cost",
    "parameters"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "attack",
        "heal",
        "buff",
        "debuff",
        "control",
        "aoe_attack",
        "aoe_heal",
        "aoe_buff",
        "aoe_debuff",
        "aoe_control"
      ]
    },
    "spell_cost": { "type": "integer", "minimum": 0 },
    "parameters": {
      "type": "object",
      "required": [
        "magnitude",
        "damage_types",
        "applied_status_effects",
        "hit_modifiers"
      ],
      "properties": {
        "magnitude": { "type": "string", "minLength": 1 },
        "damage_types": {
          "type": "array",
          "items": { "$ref": "#/$defs/damageType" }
        },
        "applied_status_effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/statusEffectReference" }
        },
        "hit_modifiers": { "type": "integer" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "damageType": {
      "type": "string",
      "enum": [
        "acid",
        "bludgeoning",
        "cold",
        "fire",
        "force",
        "lightning",
        "necrotic",
        "piercing",
        "poison",
        "psychic",
        "radiant",
        "slashing",
        "thunder"
      ]
    },
    "statusEffectReference": {
      "type": "array",
      "prefixItems": [
        { "type": "string", "minLength": 1 },
        { "type": "integer" }
      ],
      "minItems": 2,
      "maxItems": 2,
      "items": false
    },
    "spellCollection": {
      "type": "array",
      "items": { "$ref": "#" }
    }
  }
}
